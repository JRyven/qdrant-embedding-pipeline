# Production Environment Variables Template
# Copy this to .env.production and fill in actual values
# This file should be added to .gitignore and never committed

# Secrets for production
# EMBEDDING_API_KEY=your_api_key_here
# DB_USER=prod_user
# DB_PASSWORD=secure_password

# Other environment-specific variables
# PRODUCTION_DATA_DIR=/var/lib/qdrant-tagging-pipeline/data
# LOG_DIR=/var/log/qdrant-tagging-pipeline
